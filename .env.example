# Frontend (Vite)
VITE_API_URL=http://localhost:3001
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backend (server) — set these in Railway for production
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
ANTHROPIC_API_KEY=your_anthropic_key
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret
CALENDLY_API_TOKEN=your_calendly_token
QUO_API_KEY=your_quo_key

# Email — sent via the connected Gmail account (no extra API key needed)
# EMAIL_FROM_NAME is the display name shown in the From field
EMAIL_FROM_NAME=Rixey Manor

# Notifications — who receives admin alerts + daily digest
ADMIN_EMAIL=info@rixeymanor.com

# Frontend URL — used in email links (set to production URL in Railway)
FRONTEND_URL=https://your-frontend-domain.com

# CORS (comma-separated, optional — defaults to localhost)
# CORS_ORIGINS=https://your-frontend-domain.com
